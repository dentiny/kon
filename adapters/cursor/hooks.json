{
  "version": 1,
  "_note": "Template only — run scripts/setup_cursor.sh to install hooks with absolute paths.",
  "hooks": {
    "sessionStart": [
      {
        "command": "python3 $KON_ROOT/hooks/ensure_project_dir.py"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "python3 $KON_ROOT/hooks/init_kon_session.py"
      },
      {
        "command": "python3 $KON_ROOT/hooks/log_begin_prompt.py"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "python3 $KON_ROOT/hooks/no_git_write.py"
      }
    ],
    "subagentStop": [
      {
        "command": "python3 $KON_ROOT/hooks/on_subagent_stop.py"
      }
    ],
    "afterAgentResponse": [
      {
        "command": "python3 $KON_ROOT/hooks/log_begin_response.py"
      }
    ]
  }
}
