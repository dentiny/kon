{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "python3 ~/Desktop/kon/hooks/ensure_project_dir.py"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "python3 ~/Desktop/kon/hooks/no_git_write.py"
      }
    ],
    "subagentStop": [
      {
        "command": "python3 ~/Desktop/kon/hooks/on_subagent_stop.py"
      }
    ],
    "stop": [
      {
        "command": "python3 ~/Desktop/kon/hooks/verify_completion.py",
        "loop_limit": 3
      }
    ]
  }
}
