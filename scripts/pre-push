#!/bin/sh
# Pre-push hook: fail if any Python file would be reformatted by ruff.
# Setup: bash scripts/install_hooks.sh

# Find ruff: prefer project venv, fall back to PATH
REPO_ROOT="$(git rev-parse --show-toplevel)"
RUFF="$REPO_ROOT/.venv/bin/ruff"
if [ ! -x "$RUFF" ]; then
  RUFF="$(command -v ruff 2>/dev/null)"
fi
if [ -z "$RUFF" ]; then
  echo "kon pre-push: ruff not found." >&2
  echo "  Run: bash scripts/install_hooks.sh" >&2
  exit 1
fi

if ! "$RUFF" format --check . 2>/dev/null; then
  echo "Fix with: ruff format ." >&2
  exit 1
fi
